# =============================================================================
# AgentReliabilityLab — Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-a-long-random-string

# --- Database ---
# Use SQLite for local dev (default), PostgreSQL for production
DATABASE_URL=sqlite:///./data/arl.db
# DATABASE_URL=postgresql://arl:arl@localhost:5432/arl

# --- LLM Provider (pick one or leave blank to use mock mode) ---
# Option 1: Ollama (free, local — recommended for dev)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Option 2: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Option 3: Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Which provider to use: ollama | openai | anthropic | mock
LLM_PROVIDER=mock

# --- LLM-as-Judge (optional, can reuse same provider) ---
LLM_JUDGE_ENABLED=false
LLM_JUDGE_PROVIDER=mock

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_STORE=faiss

# --- Policy Engine ---
SQL_POLICY_STRICT=true
HITL_ENABLED=true
HITL_RISK_THRESHOLD=0.7

# --- CORS (Next.js dev server) ---
CORS_ORIGINS=http://localhost:3000,http://web:3000

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Next.js ---
NEXT_PUBLIC_API_URL=http://localhost:8000
